# Application URL
BASE_URL=http://localhost:3000

# Test credentials (for OTP: TEST_USER_EMAIL should be the full Mailinator address: OTP_USERNAME@MAILINATOR_DOMAIN)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=password123
# Local part only — same inbox Mailinator polls for the OTP email
OTP_USERNAME=your_inbox_local_part

# Test ID attribute (default: data-testid)
TEST_ID_ATTRIBUTE=data-testid

# Timezone
TIMEZONE=America/Los_Angeles

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Mailinator API (disposable inbox / OTP / links) — do not commit real tokens
MAILINATOR_API_TOKEN=your_token_here
MAILINATOR_DOMAIN=your_configured_domain_here
# Optional: log each poll to stdout (no token). Use when debugging missing mail.
MAILINATOR_DEBUG=false
# Optional: ms between polls when inbox is empty (default 5000). Increase if mail is slow.
MAILINATOR_POLL_INTERVAL_MS=5000
# Optional: ms to wait before the first inbox read (default 0). Helps avoid grabbing the previous newest message before the new OTP lands.
MAILINATOR_POLL_START_DELAY_MS=0

# Optional: project label for Marketing → Create wizard (react-select)
FEATHR_PROJECT_NAME=Your Project Name

# ── MidScene.js AI Visual Automation ──────────────────────────────────
# Required only for tests that use MidScene AI fixtures (ai, aiQuery, aiAssert, etc.)
# See https://midscenejs.com/model-config.html for all options.
MIDSCENE_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MIDSCENE_MODEL_API_KEY=your_gemini_api_key_here
MIDSCENE_MODEL_NAME=gemini-2.5-flash
MIDSCENE_MODEL_FAMILY=gemini
